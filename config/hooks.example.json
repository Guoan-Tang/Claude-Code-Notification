{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh.exe -ExecutionPolicy Bypass -File \"C:/Users/<username>/scripts/notify.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh.exe -ExecutionPolicy Bypass -File \"C:/Users/<username>/scripts/notify.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh.exe -ExecutionPolicy Bypass -File \"C:/Users/<username>/scripts/notify.ps1\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
